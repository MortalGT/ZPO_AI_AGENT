# --- Groq LLM ---------------------------------------------------------------
# Get a key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional: override the model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- SAP system -------------------------------------------------------------
# Base URL of your S/4HANA / Gateway system, no trailing slash
SAP_BASE_URL=https://your-sap-host:44300
SAP_USER=YOUR_SAP_USER
SAP_PASSWORD=YOUR_SAP_PASSWORD
# Optional: client number, e.g. 100
SAP_CLIENT=
# Set to false only for test systems with self-signed certificates
SAP_VERIFY_SSL=true
